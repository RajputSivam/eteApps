class Solution
{
    //Brute Foce Appraoch
    public List<List<Integer>> subsets(int[] nums)
    {
        List<List<Integer>> res=new ArrayList<>();
        help( res,new ArrayList<>(), 0,nums);
        return res;
    }
    public static void help(List<List<Integer>> res,List<Integer> ar, int idx,int[] nums )
    {

        if( idx==nums.length )
        {
            res.add( new ArrayList<>(ar) );
            return;
        }
  
        //pick
        ar.add(nums[idx]);
        help( res,ar, idx+1,nums);
        ar.remove( ar.size()-1 );
        //not pick
        help( res,ar, idx+1,nums); 
    }

    //Optimized Appraoch
    public List<List<Integer>> subsets(int[] nums)
    {
        List<List<Integer>> res=new ArrayList<>();
        int n=nums.length;
        int sb=1<<n;//no. of all subsets

        for(int num=0 ;num<sb;num++)
        {
            List<Integer> ar=new ArrayList<>();
            for(int i=0;i<n;i++)
            {
                if( (num & ( 1<<i) ) !=0)
                {
                    ar.add( nums[i] );
                }
            }
            res.add(ar);
        }
        return res;
    }
}


| Approach         | Time Complexity  | Auxiliary Space | Output Space     |
| ---------------- | ---------------- | --------------- | ---------------- |
| Backtracking     | (O(n \cdot 2^n)) | (O(n))          | (O(n \cdot 2^n)) |
| Bit Manipulation | (O(n \cdot 2^n)) | (O(n))          | (O(n \cdot 2^n)) |

