    //Brute Force Approach
    public ListNode mergeTwoLists(ListNode head1, ListNode head2)
    {
        ListNode dummy=new ListNode(-1);
        ListNode temp=dummy;
        ArrayList<Integer> ar=new ArrayList<>();

        while(head1!=null)
        {
            ar.add(head1.val);
            head1=head1.next;
        }
        while(head2!=null)
        {
            ar.add(head2.val);
            head2=head2.next;
        }
        Collections.sort(ar);
        for(int i=0;i<ar.size();i++ )
        {
            temp.next=new ListNode(ar.get(i) );
            temp=temp.next;
        }
        return dummy.next;
    }

    // Optimized approach — Two Pointer (no extra space):
    public ListNode mergeTwoLists(ListNode head1, ListNode head2)
    {
        ListNode dummy=new ListNode(-1);
        ListNode temp=dummy;

        while( head1!=null && head2!=null )
        {
            if( head1.val<=head2.val )
            {
                temp.next=head1;
                temp=temp.next;
                head1=head1.next;
            }
            else//( head1.val<=head2.val )
            {
                temp.next=head2;
                temp=temp.next;
                head2=head2.next;
            }
        }
        while(head1!=null )
        {
            temp.next=head1;
            temp=temp.next;
            head1=head1.next;
        }
        while(head2!=null )
        {
            temp.next=head2;
            temp=temp.next;
            head2=head2.next;
        }
        return dummy.next;
    }
}


| Approach                       | Time Complexity       | Space Complexity |
| ------------------------------ | --------------------- | ---------------- |
| Brute Force (ArrayList + Sort) | **O((m+n) log(m+n))** | **O(m+n)**       |
| Optimized (Two Pointers)       | **O(m+n)**            | **O(1)**         |
