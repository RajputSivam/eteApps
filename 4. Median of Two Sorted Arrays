class Solution {
    public double findMedianSortedArrays(int[] nums1, int[] nums2)
    {

        int n1=nums1.length;
        int n2=nums2.length;
        int[] res=new int[n1+n2];
        double ms=0;
        int id=0;
        for(int i=0;i<nums1.length;i++)
        {
            res[id++]=nums1[i];
        }
        for(int i=0;i<nums2.length;i++)
        {
            res[id++]=nums2[i];
        }
        Arrays.sort(res);

        int mid=res.length/2;
        if( (res.length)%2==0)
        {
            ms=(double)( res[mid]+res[mid-1])/2.0;
        }
        else 
        {
            ms=(double)res[mid];
        }
        return ms;
    }
}

| Complexity           | Value                 |
| -------------------- | --------------------- |
| **Time Complexity**  | **O((m+n) log(m+n))** |
| **Space Complexity** | **O(m+n)**            |
