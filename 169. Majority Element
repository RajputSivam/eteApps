class Solution {
    //Optmized Appraoch
    public int majorityElement(int[] nums)
    {
        HashMap<Integer,Integer> hm=new HashMap<>();
        for(int i=0;i<nums.length;i++)
        {
            hm.put(nums[i],hm.getOrDefault(nums[i],0)+1 );
        }
        int n=nums.length;
        for(int i:hm.keySet())
        {
            if( hm.get(i)>( n/2) )
            {
                return i;
            }
        }
        return -1;
    }
