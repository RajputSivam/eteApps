public class Solution {
    ////Optimized Appraoch
    public ListNode getIntersectionNode(ListNode headA, ListNode headB) {
       ListNode h1=headA;
       ListNode h2=headB;

       while( h1!=h2)
       {
            h1= (h1==null)?headB:h1.next;
            h2= (h2==null)?headA:h2.next;
       }
       return h1;
    }
    //Brute Force Appraoch
    public ListNode getIntersectionNode(ListNode headA, ListNode headB)
    {
        ListNode h1=headA;
        ListNode h2=headB;

        HashSet<ListNode> hs=new HashSet<>();
        while(h1!=null)
        {
            hs.add(h1 );
            h1=h1.next;
        }

        while(h2!=null)
        {
            if( hs.contains(h2) )
            {
                return h2;
            }
            hs.add( h2);
           
            h2=h2.next;
        }
        return null;
    }
}


| Approach                 | Time Complexity | Space Complexity |
| ------------------------ | --------------- | ---------------- |
| Brute Force (HashSet)    | **O(m + n)**    | **O(m)**         |
| Optimized (Two Pointers) | **O(m + n)**    | **O(1)**         |

