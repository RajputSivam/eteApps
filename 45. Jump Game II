class Solution {
    ///Brute Force Appraoch
    public int jump(int[] nums)
    {
        return f(nums, 0, 0);
    }
    
    static int f(int[] arr, int ind, int jumps)
    {
        // Base case
        if (ind >= arr.length - 1) return jumps;
        
        int mini = Integer.MAX_VALUE;
        
        // Try all jumps from 1 to arr[ind]
        for (int i = 1; i <= arr[ind]; i++)
        {
            mini = Math.min(mini, f(arr, ind + i, jumps + 1));
        }
        
        return mini;
    }
    ///Optimized Appraoch
    public int jump(int[] nums)
    {
        int[] dp=new int[nums.length+1];
        Arrays.fill( dp,Integer.MAX_VALUE);
        return help(nums,0,dp);
    }
    public int  help(int [] nums,int idx,int[] dp)
    {
        if( idx>=nums.length-1)
        {
            return 0;
        }
        if( dp[idx]!=Integer.MAX_VALUE)
        {
            return dp[idx];
        }
        int mn=Integer.MAX_VALUE;
        for(int i=1;i<=nums[idx];i++)
        {
            int rs=help(nums,idx+i,dp ) ;
            if( rs!=Integer.MAX_VALUE )
            {
                mn=Math.min(mn,rs+1);
            }
        }
        return dp[idx]=mn;
    }
}

| Approach                  | Time Complexity | Space Complexity |
| ------------------------- | --------------- | ---------------- |
| Brute Force Recursion     | **O(2^n)**      | **O(n)**         |
| Memoization (Top-Down DP) | **O(n²)**       | **O(n)**         |
